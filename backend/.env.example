MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_MODEL=abab6.5s-chat
# MiniMax Embedding 模型，用于课程材料向量化和 RAG 检索，保持默认即可
MINIMAX_EMBEDDING_MODEL=embo-01

SECRET_KEY=change_this_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 关系数据库 ────────────────────────────────────────────────
# 默认 SQLite（嵌入式，路径由代码自动确定）。
# 切换到 PostgreSQL 时取消注释并填写连接串：
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/zhixue

# ── 向量数据库 ────────────────────────────────────────────────
# 默认 ChromaDB（嵌入式，持久化到 backend/chroma_db/），无需配置。
# 切换到 pgvector 时填写与关系数据库相同的 PostgreSQL 连接串，
# pgvector 会在同一个 PG 实例中创建 course_material_chunks 表：
# VECTOR_DB_URL=postgresql+psycopg2://user:password@localhost:5432/zhixue

UPLOAD_DIR=./uploads
LOG_DIR=./logs
